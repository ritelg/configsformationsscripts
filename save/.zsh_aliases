alias ipa='ip -br addr show'
alias cdp='cd "$(xclip -selection clipboard -o)"'
# Utile quand je veux seulement travailler sur écran externe, et que je n'ai pas besoin de l'ecran du pc portable
alias eteindre_ecran_pc_portable='xrandr --output HDMI-1-0 --auto --output eDP-1 --off'
# Utile quand je veux restaurer mon écran du pc portable, attention faut recharger i3wm avec Windows+Shift+r
alias rallumer_ecran_pc_portable='xrandr --output HDMI-1-0 --auto --output eDP-1 --auto --right-of HDMI-1-0'
# Allumer la tour
alias proxmox_wakeup="ssh lenovo-docker 'wakeonlan d8:bb:c1:da:d9:fe'"

